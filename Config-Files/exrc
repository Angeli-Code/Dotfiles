" General Settings
set guicursor=
set nowrap
set noswapfile
set nobackup
set nowritebackup
set noundofile
set clipboard=unnamedplus
set t_ti=
set t_te=

" Formatting
set tabstop=8
set softtabstop=8
set shiftwidth=8
set smartindent
set scrolloff=8
set textwidth=80
set formatoptions+=t

" Colors
highlight NonText ctermfg=white

" Totally Not Copy And Paste
vnoremap <silent> <C-y> :w !xsel -ib<CR><Esc>
nnoremap <silent> <C-y> :"+y<CR>:call system('xsel -ib', getreg('"'))<CR>
nnoremap <silent> <C-p> :r !xsel -ob<CR>
inoremap <C-p> <C-r>=system('xsel -ob')<CR>
